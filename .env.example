# ===========================================
# Sharkbait Environment Variables
# Copy this to .env.local and fill in your keys
# ===========================================

# --- Map ---
# Sign up free: https://account.mapbox.com/auth/signup/
# Go to your account → Access tokens → copy the default public token
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- News ---
# Sign up free: https://newsapi.org/register
# Copy your API key from the dashboard
NEWS_API_KEY=
